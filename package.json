  "scripts": {
    "dev": "nuxt dev",
    "build": "NODE_OPTIONS='--max-old-space-size=4096' nuxt build",
    "build:dev": "NODE_OPTIONS='--max-old-space-size=4096' BUILD_MODE=dev nuxt build",
    "build:debug": "NODE_OPTIONS='--max-old-space-size=4096' DEBUG=nuxt:* nuxt build",
    "build:dev:debug": "NODE_OPTIONS='--max-old-space-size=4096' BUILD_MODE=dev DEBUG=nuxt:* nuxt build",
    "preview": "nuxt preview",
    "generate": "nuxt generate",
    "start": "node .output/server/index.mjs",
    "typecheck": "nuxi typecheck",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "test": "vitest",
    "test:ui": "vitest --ui",
    "test:coverage": "vitest --coverage",
    "postinstall": "nuxt prepare"
  },
