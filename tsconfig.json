{
  "extends": "./.nuxt/tsconfig.json",
  "compilerOptions": {
    "strict": true,
    "noImplicitAny": true,
    "strictNullChecks": true,
    "strictFunctionTypes": true,
    "strictBindCallApply": true,
    "strictPropertyInitialization": true,
    "noImplicitThis": true,
    "alwaysStrict": true,
    "noUnusedLocals": true,
    "noUnusedParameters": true,
    "noImplicitReturns": true,
    "noFallthroughCasesInSwitch": true,
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "allowImportingTsExtensions": true,
    "resolveJsonModule": true,
    "allowJs": true,
    "checkJs": false,
    "noEmit": true,
    "declaration": false,
    "skipLibCheck": true,
    "esModuleInterop": true,
    "allowSyntheticDefaultImports": true,
    "forceConsistentCasingInFileNames": true,
    "isolatedModules": true,
    "lib": ["ES2022", "DOM", "DOM.Iterable"],
    "types": ["node", "vitest/globals"]
    // Intentionally NOT overriding "baseUrl"/"paths" here.
    // `.nuxt/tsconfig.json` (which this file extends) defines the full set of
    // Nuxt aliases (#app, #imports, #build, #components, #server, #shared, ~, @, etc.)
    // as paths relative to ITSELF with no baseUrl of its own. TypeScript's `extends`
    // does NOT deep-merge `paths` - if a child re-declares `paths` at all, it fully
    // replaces the parent's map. Custom domain aliases are injected into the
    // generated `.nuxt/tsconfig.json` via `typescript.tsConfig` in nuxt.config.ts
    // so they are inherited here without overriding Nuxt's paths.
  },
  "include": ["**/*.ts", "**/*.tsx", "**/*.vue", "**/*.d.ts"],
  "files": [
    "types/ambient.d.ts",
    "types/vue-shims.d.ts",
    ".nuxt/nuxt.d.ts"
  ],
  "exclude": [
    "node_modules",
    ".nuxt",
    ".output",
    ".nitro",
    "dist",
    "supabase/functions"
  ]
}
