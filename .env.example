# ============================================================================
# SUPABASE DATABASE CONFIGURATION
# ============================================================================
# [REQUIRED] [SECRET] Supabase project URL
# Get from: https://app.supabase.com/project/[PROJECT_ID]/settings/general
SUPABASE_URL=https://your-project.supabase.co

# [REQUIRED] [PUBLIC] Supabase anonymous key (safe for browser)
# Get from: https://app.supabase.com/project/[PROJECT_ID]/settings/api
# This key has limited permissions (anon role only)
# PRIMARY: Use this variable name for all new code
NUXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key_here

# [REQUIRED] [PUBLIC] Supabase URL (public version)
# Get from: https://app.supabase.com/project/[PROJECT_ID]/settings/general
NUXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co

# [REQUIRED] [SECRET] Supabase service role key (server-side only)
# Get from: https://app.supabase.com/project/[PROJECT_ID]/settings/api
# ⚠️ CRITICAL: Never expose this to browser! Server-side only!
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key_here

# Legacy/Alternative names (for backward compatibility)
# If your code uses these, map them to the standard names above
SUPABASE_ANON_KEY=${NUXT_PUBLIC_SUPABASE_ANON_KEY}
SUPABASE_KEY=${NUXT_PUBLIC_SUPABASE_ANON_KEY}
NUXT_PUBLIC_SUPABASE_KEY=${NUXT_PUBLIC_SUPABASE_ANON_KEY}
